# 复制本文件为 .env.local 并填入真实 Key，右上角设置中会显示配置状态（不展示明文）
# 复制命令：cp .env.example .env.local
# 注意：不要将真实 Key 写进本文件，本文件可能被提交到 Git

# OpenAI（荟萃分析 GPT、一键综述 GPT、RAG 索引）
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# 智谱（荟萃分析 GLM、一键综述 GLM）
ZHIPU_API_KEY=
ZHIPU_BASE_URL=
ZHIPU_MODEL=

# Firecrawl（缺摘要时兜底抓取，可选）
FIRECRAWL_API_KEY=

# OpenAlex 联系邮箱（批量检索时建议填写，可选）
OPENALEX_EMAIL=
